<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:orientation="vertical"
        android:padding="14dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Category name and percentage -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvCatName"
                android:text="Category"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvCatPct"
                android:text="0%"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#1E442F"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Amount spent vs limit -->
        <TextView
            android:id="@+id/tvCatSpent"
            android:text="ZAR 0.00 / ZAR 0.00"
            android:textSize="12sp"
            android:textColor="#777777"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Progress bar: green < 80%, orange 80-99%, red 100%+ -->
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progressCat"
            android:progress="0"
            app:indicatorColor="#1E442F"
            app:trackColor="#E0E0E0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>