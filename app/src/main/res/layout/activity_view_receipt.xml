<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true"> <LinearLayout
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="15dp"
    android:background="#1E442F"
    android:layout_width="match_parent"
    android:layout_height="60dp">

    <ImageView
        android:id="@+id/ivBack"
        android:src="@android:drawable/ic_media_previous"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:padding="4dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="#BBF0AE" />

    <TextView
        android:text="Receipt"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#BBF0AE"
        android:layout_marginStart="12dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>

    <LinearLayout
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#1E442F"
        android:gravity="center_vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tvReceiptTitle"
                android:text="Transaction"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvReceiptCat"
                android:text="Category"
                android:textSize="13sp"
                android:textColor="#BBF0AE"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/tvReceiptDate"
                android:text="Date"
                android:textSize="12sp"
                android:textColor="#AAAAAA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvReceiptAmount"
            android:text="-ZAR0.00"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/holo_red_dark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <ImageView
        android:id="@+id/ivFullReceipt"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scaleType="fitCenter"
        android:src="@android:drawable/ic_menu_gallery"
        android:padding="8dp"/>

</LinearLayout>